#!/bin/sh
# Get absolute path to interpreters directory and change to it
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
INTERPRETERS_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$INTERPRETERS_DIR" || exit 1

echo "Running pre-commit checks..."

STAGED_FILES_RELATIVE=$(git diff --cached --name-only --diff-filter=ACMR | grep "^interpreters/" | grep -E '\.(ts|tsx|js|jsx|json|md|yml)$' | sed 's|^interpreters/||' || true)

if [ -z "$STAGED_FILES_RELATIVE" ]; then
    echo "No staged files — skipping format and lint."
else
    STAGED_FILES_ABSOLUTE=$(echo "$STAGED_FILES_RELATIVE" | sed "s|^|$INTERPRETERS_DIR/|")

    echo "💅 Formatting staged files..."
    echo "$STAGED_FILES_ABSOLUTE" | tr '\n' '\0' | xargs -0 pnpm exec prettier --write
    if [ $? -ne 0 ]; then
        echo "❌ Formatting failed. Commit aborted."
        exit 1
    fi

    echo "🔍 Running lint on staged files..."
    echo "$STAGED_FILES_ABSOLUTE" | tr '\n' '\0' | xargs -0 pnpm exec eslint --max-warnings=0
    if [ $? -ne 0 ]; then
        echo "❌ Lint check failed. Commit aborted."
        exit 1
    fi

    # Re-add any files that were auto-formatted
    git add $STAGED_FILES_RELATIVE
fi

# Run type check
echo "🔍 Type checking..."
pnpm run typecheck
if [ $? -ne 0 ]; then
    echo "❌ Type check failed. Commit aborted."
    exit 1
fi

# Run tests
echo "🧪 Running tests..."
pnpm test
if [ $? -ne 0 ]; then
    echo "❌ Tests failed. Commit aborted."
    exit 1
fi

# Run benchmark tests
echo "⚡ Running benchmark tests..."
pnpm test:benchmark
if [ $? -ne 0 ]; then
    echo "❌ Benchmark tests failed. Commit aborted."
    exit 1
fi

echo "✅ All checks passed!"
