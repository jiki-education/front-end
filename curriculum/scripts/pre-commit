#!/bin/sh
# Get absolute path to curriculum directory and change to it
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CURRICULUM_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$CURRICULUM_DIR" || exit 1

echo "Running pre-commit checks..."

# Run TypeScript type checking
echo "🔷 Running TypeScript type check..."
pnpm exec tsc --noEmit
if [ $? -ne 0 ]; then
    echo "❌ TypeScript type check failed. Commit aborted."
    exit 1
fi

STAGED_FILES_RELATIVE=$(git diff --cached --name-only --diff-filter=ACMR | grep "^curriculum/" | grep -E '\.(ts|tsx|js|jsx|mjs|css|json|md|yml|yaml)$' | sed 's|^curriculum/||' || true)

if [ -z "$STAGED_FILES_RELATIVE" ]; then
    echo "No staged files — skipping format and lint."
else
    STAGED_FILES_ABSOLUTE=$(echo "$STAGED_FILES_RELATIVE" | sed "s|^|$CURRICULUM_DIR/|")

    echo "💅 Formatting staged files..."
    echo "$STAGED_FILES_ABSOLUTE" | tr '\n' '\0' | xargs -0 pnpm exec prettier --write
    if [ $? -ne 0 ]; then
        echo "❌ Formatting failed. Commit aborted."
        exit 1
    fi

    echo "🔍 Running lint on staged files..."
    echo "$STAGED_FILES_ABSOLUTE" | tr '\n' '\0' | xargs -0 pnpm exec eslint --max-warnings=0
    if [ $? -ne 0 ]; then
        echo "❌ Lint check failed. Commit aborted."
        exit 1
    fi

    # Re-add any files that were auto-formatted
    git add $STAGED_FILES_RELATIVE
fi

# Run tests
echo "🧪 Running tests..."
pnpm test
if [ $? -ne 0 ]; then
    echo "❌ Tests failed. Commit aborted."
    exit 1
fi

echo "✅ All checks passed!"
