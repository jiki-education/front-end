set height to 10
set width to 20

set col to 0
set y to 100

set row_index to -1
set num_iterations to 0

repeat 10 times do
  change y to y - height
  change row_index to row_index + 1
  if row_index % 2 == 0 do
    change col to 0
    change num_iterations to 5
  else do
    change col to -0.5
    change num_iterations to 6
  end

  repeat num_iterations times do
    rectangle(col * width, y, width, height, "brick")
    change col to col + 1
  end
end
