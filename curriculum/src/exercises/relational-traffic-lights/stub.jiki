set red to "red"
set yellow to "amber"
set green to "green"
set housing_color to "charcoal"
set radius to 10

set center_x to 0
set red_y to 0
set yellow_y to 0
set green_y to 0
set housing_x to 0
set housing_y to 0
set housing_width to 0
set housing_height to 0

rectangle(housing_x, housing_y, housing_width, housing_height, housing_color)

circle(center_x, red_y, radius, red)

circle(center_x, yellow_y, radius, yellow)

circle(center_x, green_y, radius, green)
