let red = "red";
let yellow = "amber";
let green = "green";
let housingColor = "charcoal";
let radius = 10;

let centerX = 0;
let redY = 0;
let yellowY = 0;
let greenY = 0;
let housingX = 0;
let housingY = 0;
let housingWidth = 0;
let housingHeight = 0;

rectangle(housingX, housingY, housingWidth, housingHeight, housingColor);

circle(centerX, redY, radius, red);

circle(centerX, yellowY, radius, yellow);

circle(centerX, greenY, radius, green);
