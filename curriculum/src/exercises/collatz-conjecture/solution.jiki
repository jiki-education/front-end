// Receives a number as its input
// Should return the number of steps to reach 1
function collatz_steps with number do
  set idx to 0
  repeat_forever do
    if(number == 1) do
      return idx
    end

    if number % 2 == 0 do
      change number to number / 2
    else do
      change number to (number * 3) + 1
    end
    change idx to idx + 1

  end
end