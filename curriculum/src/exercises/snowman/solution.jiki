set snowman_center_x to 50
set head_center_y to 20
set head_radius to 10
set body_center_y to 40
set body_radius to 15
set base_center_y to 70
set base_radius to 20

// Base (bottom, biggest)
circle(snowman_center_x, base_center_y, base_radius, "white")

// Body (middle)
circle(snowman_center_x, body_center_y, body_radius, "white")

// Head (top, smallest)
circle(snowman_center_x, head_center_y, head_radius, "white")
