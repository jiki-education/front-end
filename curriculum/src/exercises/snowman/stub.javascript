// Fix these variables, then add the ones for the body and head
let snowmanCenterX = 20
let baseCenterY = 60
let baseRadius = 10

// Base (bottom, biggest)
circle(snowmanCenterX, baseCenterY, baseRadius, "white")

// Body (middle)
circle(snowmanCenterX, bodyCenterY, bodyRadius, "white")

// Head (top, smallest)
circle(snowmanCenterX, headCenterY, headRadius, "white")
