// Fix these variables, then add the ones for the body and head
let snowmanCx = 20;
let baseCy = 60;
let baseRadius = 10;

// Base (bottom, biggest)
circle(snowmanCx, baseCy, baseRadius, "white");

// Body (middle)
circle(snowmanCx, bodyCy, bodyRadius, "white");

// Head (top, smallest)
circle(snowmanCx, headCy, headRadius, "white");
