set floors to num_floors() - 1
set y to 2
set x to 19

build_wall(x - 2, y)
build_glass(x - 1, y)
build_entrance(x, y)
build_glass(x + 1, y)
build_wall(x + 2, y)
change y to y + 1

repeat floors times do
  build_wall(x - 2, y)
  build_glass(x - 1, y)
  build_glass(x, y)
  build_glass(x + 1, y)
  build_wall(x + 2, y)
  change y to y + 1
end

build_wall(x - 2, y)
build_wall(x - 1, y)
build_wall(x, y)
build_wall(x + 1, y)
build_wall(x + 2, y)
